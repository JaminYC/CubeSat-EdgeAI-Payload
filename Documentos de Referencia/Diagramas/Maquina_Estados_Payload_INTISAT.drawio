<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" type="device">
  <diagram name="Payload State Machine" id="payload-fsm-intisat">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1000" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="TITLE_PL" value="Maquina de estados del Payload (microscopia FPM) - INTISAT" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#7D3C98;" vertex="1" parent="1"><mxGeometry x="80" y="10" width="1840" height="40" as="geometry"/></mxCell><mxCell id="OBC_TRIG" value="OBC pasa a Estado F
(activar payload)

EHPC = 1, ECB = 1, ZV = 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#34495E;strokeColor=#1B2631;fontColor=#FFFFFF;fontSize=11;fontStyle=1;strokeWidth=2;arcSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="80" y="340" width="240" height="80" as="geometry"/></mxCell><mxCell id="P_OFF" value="&lt;b&gt;&lt;u&gt;OFF: Payload apagado&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;OBC fuera de Estado F&lt;br&gt;CM5 sin alimentacion&lt;br&gt;Camara, LEDs y FPGA OFF&lt;br&gt;ECB irrelevante (no consumo)&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;CMD_PL_ON recibido del OBC&lt;br&gt;(OBC en Estado F + EHPC = 1)&lt;br&gt;Alimentar CM5 -&amp;gt; ir a BOOT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D4AC0D;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="80" y="60" width="240" height="220" as="geometry"/></mxCell><mxCell id="P_BOOT" value="&lt;b&gt;&lt;u&gt;BOOT: Arranque CM5 y drivers&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;CMD_PL_ON activo, alimentando&lt;br&gt;CM5 booteando Linux + daemon&lt;br&gt;T = 0s, BOOT_OK = 0&lt;br&gt;Cargar drivers camara, LEDs&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;T &amp;lt;= T_BOOT (timeout 60s)&lt;br&gt;BOOT_OK = 1, daemon arriba&lt;br&gt;Drivers cargados sin errores&lt;br&gt;ERR_BOOT_PL = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D4AC0D;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="400" y="60" width="240" height="220" as="geometry"/></mxCell><mxCell id="P_CAL" value="&lt;b&gt;&lt;u&gt;CAL: Calibracion optica&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;BOOT_OK = 1&lt;br&gt;Camara y LEDs respondiendo&lt;br&gt;TEMP_CMOS dentro de rango&lt;br&gt;(verificar -10C a 40C)&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;CAM_OK = 1 (test pattern OK)&lt;br&gt;LED_OK = 1 (todos LEDs probados)&lt;br&gt;FOCUS_OK = 1 (autofocus listo)&lt;br&gt;-&amp;gt; ir a IDLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAEF;strokeColor=#7D3C98;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="720" y="60" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_IDLE" value="&lt;b&gt;&lt;u&gt;IDLE: Espera comando&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;CAL completa, todo nominal&lt;br&gt;Buffers vacios, disco con espacio&lt;br&gt;DISK_OK = 1, ECB = 1&lt;br&gt;Consumo bajo (~3W)&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;CMD_CAP -&amp;gt; ir a WARMUP&lt;br&gt;OR CMD_DL + BS_READY -&amp;gt; DLPREP&lt;br&gt;OR ECB = 0 -&amp;gt; ir a LP&lt;br&gt;OR ERR_* = 1 -&amp;gt; ir a ERR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1040" y="60" width="240" height="220" as="geometry"/></mxCell><mxCell id="P_WARM" value="&lt;b&gt;&lt;u&gt;WARMUP: Estabilizacion termica&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;CMD_CAP recibido&lt;br&gt;T_WARM = 0s&lt;br&gt;Encender LED array progresivo&lt;br&gt;Monitorear TEMP_CMOS, TEMP_LED&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;T_WARM &amp;gt;= T_w (~30s)&lt;br&gt;TEMP_CMOS estable&lt;br&gt;TEMP_LED estable&lt;br&gt;-&amp;gt; ir a CAPT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1040" y="340" width="240" height="200" as="geometry"/></mxCell><mxCell id="P_CAPT" value="&lt;b&gt;&lt;u&gt;CAPT: Captura FPM&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;WARMUP OK, sistema termico&lt;br&gt;N_CAP = 0, N_TARGET = 49..225&lt;br&gt;(secuencia LED de N angulos)&lt;br&gt;Camara en modo captura RAW&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;N_CAP = N_TARGET&lt;br&gt;(secuencia FPM completa)&lt;br&gt;IMG_BUF lleno, listo procesar&lt;br&gt;-&amp;gt; ir a PROC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1360" y="340" width="240" height="220" as="geometry"/></mxCell><mxCell id="P_PROC" value="&lt;b&gt;&lt;u&gt;PROC: Procesamiento FPM + IA&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;IMG_BUF completo (N_TARGET img)&lt;br&gt;Iniciar reconstruccion FPM&lt;br&gt;Luego Real-ESRGAN super-resol.&lt;br&gt;GPU CM5 activa (~6W extra)&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;PROC_DONE = 1&lt;br&gt;Imagen reconstruida + SR lista&lt;br&gt;OR ERR_PROC = 1 -&amp;gt; ir a ERR&lt;br&gt;-&amp;gt; ir a STORE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1680" y="340" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_STORE" value="&lt;b&gt;&lt;u&gt;STORE: Almacenamiento&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;PROC_DONE = 1&lt;br&gt;Imagen final + metadata listas&lt;br&gt;Compresion (PNG/JPEG-XL)&lt;br&gt;Calcular checksum CRC32&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;Archivo escrito a disco&lt;br&gt;DISK_OK actualizado&lt;br&gt;Log entry registrada&lt;br&gt;-&amp;gt; volver a IDLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1680" y="60" width="240" height="200" as="geometry"/></mxCell><mxCell id="P_DLPREP" value="&lt;b&gt;&lt;u&gt;DLPREP: Preparacion downlink&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;CMD_DL recibido del OBC&lt;br&gt;Hay archivos pendientes en disco&lt;br&gt;ZS = 1 (en zona ventana)&lt;br&gt;Banda S inicializandose&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;BS_READY = 1&lt;br&gt;Paquetes CCSDS armados&lt;br&gt;Lock con estacion confirmado&lt;br&gt;-&amp;gt; ir a DL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="720" y="340" width="240" height="220" as="geometry"/></mxCell><mxCell id="P_DL" value="&lt;b&gt;&lt;u&gt;DL: Downlink activo (banda S)&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;BS_READY = 1, BS_TX = 1&lt;br&gt;Transmitiendo a estacion&lt;br&gt;Consumo alto (~12W)&lt;br&gt;Monitorear errores TX&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;Todos los archivos enviados&lt;br&gt;OR ZS = 0 (fin de ventana)&lt;br&gt;OR ECB = 0 -&amp;gt; ir a LP&lt;br&gt;-&amp;gt; volver a IDLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="400" y="340" width="240" height="220" as="geometry"/></mxCell><mxCell id="P_LP" value="&lt;b&gt;&lt;u&gt;LP: Bajo consumo&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;ECB = 0 desde cualquier estado&lt;br&gt;Apagar LEDs, FPGA, banda S&lt;br&gt;CM5 en suspend (~0.5W)&lt;br&gt;Mantener daemon vivo&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;ECB = 1 sostenido (&amp;gt;5 min)&lt;br&gt;OR CMD_PL_OFF -&amp;gt; ir a OFF&lt;br&gt;Retomar IDLE si todo OK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="80" y="620" width="240" height="200" as="geometry"/></mxCell><mxCell id="P_ERR" value="&lt;b&gt;&lt;u&gt;ERR: Estado de error&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;ERR_CAM | ERR_LED | ERR_PROC = 1&lt;br&gt;Detener operacion actual&lt;br&gt;Registrar error en log&lt;br&gt;Notificar al OBC (telemetria)&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;Recovery automatico -&amp;gt; ir a CAL&lt;br&gt;(intentar 3 veces)&lt;br&gt;OR CMD_PL_OFF -&amp;gt; ir a OFF&lt;br&gt;OR error fatal -&amp;gt; permanecer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="400" y="620" width="240" height="200" as="geometry"/></mxCell><mxCell id="PE1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" source="OBC_TRIG" target="P_OFF" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE1_T" value="Trigger:&#10;Reset / power-on inicial" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE1"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE1_X" value="Transition:&#10;Payload en estado OFF" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE1"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="P_OFF" target="P_BOOT" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE2_T" value="Trigger:&#10;CMD_PL_ON del OBC&#10;(OBC en Estado F)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE2"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE2_X" value="Transition:&#10;Alimentar CM5, T = 0s,&#10;BOOT_OK = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE2"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="P_BOOT" target="P_CAL" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE3_T" value="Trigger:&#10;BOOT_OK = 1&#10;Drivers cargados" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE3"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE3_X" value="Transition:&#10;Iniciar CAM_SELFTEST,&#10;LED_SELFTEST, FOCUS_CAL" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE3"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="P_CAL" target="P_IDLE" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE4_T" value="Trigger:&#10;CAM_OK = 1 AND LED_OK = 1&#10;AND FOCUS_OK = 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE4"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE4_X" value="Transition:&#10;DISK_OK = 1,&#10;LEDs en modo bajo, esperar" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE4"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="P_IDLE" target="P_WARM" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE5_T" value="Trigger:&#10;CMD_CAP recibido" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE5"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE5_X" value="Transition:&#10;Encender LEDs progresivo,&#10;T_WARM = 0s" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE5"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="P_WARM" target="P_CAPT" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE6_T" value="Trigger:&#10;T_WARM &gt;= T_w AND&#10;TEMP_CMOS y TEMP_LED OK" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE6"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE6_X" value="Transition:&#10;Camara modo RAW,&#10;N_CAP = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE6"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="P_CAPT" target="P_PROC" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE7_T" value="Trigger:&#10;N_CAP = N_TARGET&#10;(secuencia completa)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE7"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE7_X" value="Transition:&#10;Apagar LEDs,&#10;iniciar reconstruccion FPM" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE7"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" source="P_PROC" target="P_STORE" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE8_T" value="Trigger:&#10;PROC_DONE = 1&#10;(FPM + SR completo)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE8"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE8_X" value="Transition:&#10;Comprimir resultado,&#10;calcular CRC32" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE8"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="P_STORE" target="P_IDLE" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE9_T" value="Trigger:&#10;Archivo escrito,&#10;log entry OK" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE9"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE9_X" value="Transition:&#10;Liberar buffers,&#10;actualizar DISK_OK" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE9"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="P_IDLE" target="P_DLPREP" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE10_T" value="Trigger:&#10;CMD_DL del OBC AND&#10;ZS = 1 (zona ventana)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE10"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE10_X" value="Transition:&#10;Inicializar banda S,&#10;armar paquetes CCSDS" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE10"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="P_DLPREP" target="P_DL" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE11_T" value="Trigger:&#10;BS_READY = 1&#10;Lock con estacion" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE11"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE11_X" value="Transition:&#10;BS_TX = 1, comenzar TX,&#10;consumo alto (~12W)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE11"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" source="P_DL" target="P_IDLE" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE12_T" value="Trigger:&#10;Archivos enviados&#10;OR ZS = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE12"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE12_X" value="Transition:&#10;BS_TX = 0, apagar banda S,&#10;log de transmision" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE12"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.25;exitY=1;entryX=0.75;entryY=0;dashed=1;" edge="1" source="P_IDLE" target="P_LP" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE13_T" value="Trigger:&#10;ECB = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE13"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE13_X" value="Transition:&#10;Apagar perifericos,&#10;CM5 en suspend" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE13"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=1;entryX=1;entryY=0.25;dashed=1;" edge="1" source="P_CAPT" target="P_LP" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE14_T" value="Trigger:&#10;ECB = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE14"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE14_X" value="Transition:&#10;Abortar captura,&#10;descartar buffer" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE14"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=1;entryX=1;entryY=0.5;dashed=1;" edge="1" source="P_DL" target="P_LP" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE15_T" value="Trigger:&#10;ECB = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE15"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE15_X" value="Transition:&#10;Abortar TX banda S" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE15"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0;entryX=0.25;entryY=1;dashed=1;" edge="1" source="P_LP" target="P_IDLE" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE16_T" value="Trigger:&#10;ECB = 1 sostenido (&gt;5min)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE16"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE16_X" value="Transition:&#10;Reanudar CM5, volver a idle" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE16"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.75;exitY=0;entryX=0;entryY=1;dashed=1;" edge="1" source="P_LP" target="P_OFF" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE17_T" value="Trigger:&#10;CMD_PL_OFF del OBC" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE17"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE17_X" value="Transition:&#10;Apagar CM5 totalmente" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE17"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=1;entryX=1;entryY=0;dashed=1;" edge="1" source="P_CAL" target="P_ERR" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE18_T" value="Trigger:&#10;ERR_CAM | ERR_LED = 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE18"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE18_X" value="Transition:&#10;Log error,&#10;notificar OBC" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE18"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=1;entryX=1;entryY=0.25;dashed=1;" edge="1" source="P_PROC" target="P_ERR" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE19_T" value="Trigger:&#10;ERR_PROC = 1&#10;(FPM o SR fallaron)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE19"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE19_X" value="Transition:&#10;Descartar resultado,&#10;log error" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE19"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0;entryX=0.25;entryY=1;dashed=1;" edge="1" source="P_ERR" target="P_CAL" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PE20_T" value="Trigger:&#10;Recovery: reintentar&#10;(max 3 veces)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="PE20"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="PE20_X" value="Transition:&#10;Resetear drivers,&#10;recalibrar" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="PE20"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="LEGEND_PL" value="&lt;b&gt;&lt;u&gt;Leyenda de flags del payload&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;b&gt;CMD_PL_ON / OFF&lt;/b&gt; = comandos OBC (encendido)&lt;br&gt;&lt;b&gt;CMD_CAP&lt;/b&gt; = comando de captura FPM&lt;br&gt;&lt;b&gt;CMD_DL&lt;/b&gt; = comando de downlink banda S&lt;br&gt;&lt;b&gt;BOOT_OK&lt;/b&gt; = CM5 + daemon listos&lt;br&gt;&lt;b&gt;CAM_OK&lt;/b&gt; = camara responde y test pattern OK&lt;br&gt;&lt;b&gt;LED_OK&lt;/b&gt; = todos los LEDs del array OK&lt;br&gt;&lt;b&gt;FOCUS_OK&lt;/b&gt; = autofocus calibrado&lt;br&gt;&lt;b&gt;TEMP_CMOS&lt;/b&gt; = temperatura sensor (-10 a 40C)&lt;br&gt;&lt;b&gt;TEMP_LED&lt;/b&gt; = temperatura array LED&lt;br&gt;&lt;b&gt;T_WARM&lt;/b&gt; = timer warmup, &lt;b&gt;T_w&lt;/b&gt; = umbral (~30s)&lt;br&gt;&lt;b&gt;N_CAP&lt;/b&gt; = imagenes capturadas en secuencia&lt;br&gt;&lt;b&gt;N_TARGET&lt;/b&gt; = imagenes objetivo FPM (49..225)&lt;br&gt;&lt;b&gt;IMG_BUF&lt;/b&gt; = buffer de captura en RAM&lt;br&gt;&lt;b&gt;PROC_DONE&lt;/b&gt; = reconstruccion FPM + SR terminada&lt;br&gt;&lt;b&gt;BS_READY&lt;/b&gt; = banda S inicializada&lt;br&gt;&lt;b&gt;BS_TX&lt;/b&gt; = transmision activa&lt;br&gt;&lt;b&gt;DISK_OK&lt;/b&gt; = espacio en disco disponible&lt;br&gt;&lt;b&gt;ERR_CAM/LED/PROC&lt;/b&gt; = flags de error&lt;br&gt;&lt;b&gt;ECB&lt;/b&gt; = energia suficiente (heredado del OBC)&lt;br&gt;&lt;b&gt;ZS / ZV&lt;/b&gt; = zona ventana / experimental (del OBC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFCFC;strokeColor=#566573;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="720" y="620" width="320" height="340" as="geometry"/></mxCell><mxCell id="SUBTITLE_PL" value="Payload sobre Raspberry Pi CM5. Se activa cuando el OBC entra en Estado F. Formato adaptado del documento &#34;HW State Machine - Neils Vilchez&#34;." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#566573;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="80" y="970" width="1840" height="20" as="geometry"/></mxCell></root>
    </mxGraphModel>
  </diagram>
</mxfile>
