<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" type="device">
  <diagram name="OBC State Machine" id="obc-fsm-intisat">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="900" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="TITLE" value="Maquina de estados del OBC - CubeSat INTISAT" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1A5276;" vertex="1" parent="1"><mxGeometry x="240" y="10" width="1520" height="40" as="geometry"/></mxCell><mxCell id="EYECT" value="Eyeccion&#10;del CubeSat" style="ellipse;whiteSpace=wrap;html=1;fillColor=#34495E;strokeColor=#1B2631;fontColor=#FFFFFF;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="80" y="140" width="120" height="80" as="geometry"/></mxCell><mxCell id="ST_A" value="&lt;b&gt;&lt;u&gt;Estado A: Verificacion de arranque&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;Eyeccion del CubeSat detectada&lt;br&gt;T = 0s, GL = 1, ECB = 1&lt;br&gt;ERR_BOOT = 1 (al inicio)&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;T &amp;gt;= 30 min&lt;br&gt;BUS_OK = 1&lt;br&gt;MAG_OK = 1&lt;br&gt;ERR_BOOT = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D4AC0D;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="240" y="60" width="240" height="220" as="geometry"/></mxCell><mxCell id="ST_B" value="&lt;b&gt;&lt;u&gt;Estado B: Estabilizacion de rotacion&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;BUS_OK = 1 AND MAG_OK = 1&lt;br&gt;ERR_BOOT = 0&lt;br&gt;MTQ_EN = 1 (magnetorquers activos)&lt;br&gt;ECB = 1&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;Rotacion residual aceptable&lt;br&gt;ERR_DET = 0&lt;br&gt;Listo para verificar antenas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="560" y="60" width="240" height="220" as="geometry"/></mxCell><mxCell id="ST_VC" value="&lt;b&gt;&lt;u&gt;Estado VC: Verificacion despliegue antenas&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;MTQ_EN = 0 (estabilizacion OK)&lt;br&gt;ECB = 1&lt;br&gt;AD = 0 | 1 | 2 (lectura inicial)&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;AD = 1 -&amp;gt; ir a VS&lt;br&gt;AD = 0 AND N_DA &amp;lt; 3 -&amp;gt; ir a C&lt;br&gt;AD != 1 AND N_DA = 3&lt;br&gt;AND N_DR &amp;lt; 2 -&amp;gt; ir a C_R" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D4AC0D;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="880" y="60" width="240" height="240" as="geometry"/></mxCell><mxCell id="ST_C" value="&lt;b&gt;&lt;u&gt;Estado C: Despliegue de antenas&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;N_DA &amp;lt; 3&lt;br&gt;AD = 0 (antenas no desplegadas)&lt;br&gt;ECB = 1, CMD_DA = 1&lt;br&gt;T_DEP = 0s&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;T_DEP = Td (tiempo cumplido)&lt;br&gt;N_DA = N_DA + 1&lt;br&gt;Volver a VC para reverificar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="880" y="360" width="240" height="200" as="geometry"/></mxCell><mxCell id="ST_CR" value="&lt;b&gt;&lt;u&gt;Estado C_R: Despliegue redundante&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;AD != 1 AND N_DA = 3&lt;br&gt;(despliegue principal fallo)&lt;br&gt;N_DR &amp;lt; 2, ECB = 1&lt;br&gt;ERR_ANT = 0&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;T_DEP = Td&lt;br&gt;N_DR = N_DR + 1&lt;br&gt;Volver a VC para reverificar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1200" y="360" width="240" height="200" as="geometry"/></mxCell><mxCell id="ST_VS" value="&lt;b&gt;&lt;u&gt;Estado VS: Verificacion de subsistemas&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;AD = 1 (antenas OK)&lt;br&gt;ECB = 1&lt;br&gt;Verificar sensores, memorias,&lt;br&gt;transceivers, buses OBC/EPS/UHF&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;Todos los subsistemas operativos&lt;br&gt;EHPC = 1 (energia para payload)&lt;br&gt;Listo para modo nominal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D4AC0D;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1200" y="60" width="240" height="220" as="geometry"/></mxCell><mxCell id="ST_D" value="&lt;b&gt;&lt;u&gt;Estado D: Nominal&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;EHPC = 1, ECB = 1&lt;br&gt;AD = 1, GL = 0&lt;br&gt;Beacon UHF activo&lt;br&gt;Telemetria almacenada en OBC&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;ZS = 1 (entrada zona solar)&lt;br&gt;-&amp;gt; ir a Estado E (ventana)&lt;br&gt;OR ECB = 0 -&amp;gt; ir a STB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1520" y="60" width="240" height="200" as="geometry"/></mxCell><mxCell id="ST_E" value="&lt;b&gt;&lt;u&gt;Estado E: Ventana&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;ZS = 1 (en zona ventana)&lt;br&gt;EHPC = 1&lt;br&gt;Preparado para downlink UHF&lt;br&gt;y/o transicion a zona solar&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;ZV = 1 -&amp;gt; ir a Estado F&lt;br&gt;OR ZS = 0 -&amp;gt; volver a D&lt;br&gt;OR ECB = 0 -&amp;gt; ir a STB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1520" y="300" width="240" height="220" as="geometry"/></mxCell><mxCell id="ST_F" value="&lt;b&gt;&lt;u&gt;Estado F: Adquisicion solar y payload&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;ZV = 1 (zona experimental OK)&lt;br&gt;ZE = 0, EHPC = 1&lt;br&gt;Payload activo (microscopia)&lt;br&gt;Banda S preparada para downlink&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;ZE = 1 (experimento terminado)&lt;br&gt;-&amp;gt; volver a Estado D&lt;br&gt;OR ECB = 0 -&amp;gt; ir a STB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1200" y="620" width="240" height="220" as="geometry"/></mxCell><mxCell id="ST_STB" value="&lt;b&gt;&lt;u&gt;Estado STB: Standby&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;ECB = 0 (desde cualquier estado)&lt;br&gt;Energia insuficiente&lt;br&gt;Apagar payload y MTQ&lt;br&gt;Solo OBC + EPS minimo&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;ECB = 1 (recuperacion solar)&lt;br&gt;-&amp;gt; volver al ultimo estado valido&lt;br&gt;OR ECB = 0 persistente&lt;br&gt;-&amp;gt; ir a Estado SV" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="560" y="620" width="240" height="200" as="geometry"/></mxCell><mxCell id="ST_SV" value="&lt;b&gt;&lt;u&gt;Estado SV: Supervivencia&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Entry Condition:&lt;/u&gt;&lt;br&gt;ECB = 0 sostenido tras STB&lt;br&gt;Modo de ultimo recurso&lt;br&gt;Solo watchdog + carga solar&lt;br&gt;Beacon minimo si hay energia&lt;br&gt;&lt;br&gt;&lt;u&gt;Exit Condition:&lt;/u&gt;&lt;br&gt;(Ultimo estado del OBC)&lt;br&gt;ECB = 1 recuperacion -&amp;gt; STB&lt;br&gt;Sin energia: permanece aqui" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="240" y="620" width="240" height="200" as="geometry"/></mxCell><mxCell id="E1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="EYECT" target="ST_A" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="E1_T" value="Trigger:&#10;Eyeccion del CubeSat" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="E1"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E1_X" value="Transition:&#10;Arranque OBC, T = 0s,&#10;GL = 1, BUS_OK = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="E1"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="ST_A" target="ST_B" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="E2_T" value="Trigger:&#10;T &gt;= 30 min AND&#10;BUS_OK = 1 AND MAG_OK = 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="E2"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E2_X" value="Transition:&#10;Activacion de MTQ_EN,&#10;ERR_BOOT = 0" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="E2"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="ST_B" target="ST_VC" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="E3_T" value="Trigger:&#10;Rotacion estabilizada&#10;(ERR_DET = 0)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="E3"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E3_X" value="Transition:&#10;Desactivacion de MTQ_EN,&#10;Iniciar verificacion antenas" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="E3"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="ST_VC" target="ST_C" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="E4_T" value="Trigger:&#10;AD = 0 AND N_DA &lt; 3" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="E4"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E4_X" value="Transition:&#10;CMD_DA = 1,&#10;T_DEP = 0s" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="E4"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0.25;exitY=0;entryX=0.75;entryY=1;" edge="1" source="ST_C" target="ST_VC" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="E5_T" value="Trigger:&#10;T_DEP = Td&#10;(timeout despliegue)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="E5"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E5_X" value="Transition:&#10;N_DA = N_DA + 1,&#10;Reverificar AD" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="E5"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=1;entryX=0.5;entryY=0;" edge="1" source="ST_VC" target="ST_CR" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="E6_T" value="Trigger:&#10;AD != 1 AND N_DA = 3&#10;AND N_DR &lt; 2" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="E6"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E6_X" value="Transition:&#10;Activar mecanismo redundante,&#10;T_DEP = 0s" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="E6"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=0;exitY=0;entryX=1;entryY=1;" edge="1" source="ST_CR" target="ST_VC" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="E7_T" value="Trigger:&#10;T_DEP = Td&#10;(timeout despliegue red.)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFFFFF;fontSize=9;fontColor=#1A5276;" vertex="1" connectable="0" parent="E7"><mxGeometry x="-0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E7_X" value="Transition:&#10;N_DR = N_DR + 1,&#10;Reverificar AD" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=#FFF8DC;fontSize=9;fontColor=#7D6608;" vertex="1" connectable="0" parent="E7"><mxGeometry x="0.4" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="E8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entr