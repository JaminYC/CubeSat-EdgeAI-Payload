      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="TITLE_PLE" value="Estados del payload con analisis energetico - INTISAT FPM" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1A5276;" vertex="1" parent="1"><mxGeometry x="80" y="10" width="1840" height="40" as="geometry"/></mxCell><mxCell id="P_OFF" value="&lt;b&gt;&lt;u&gt;OFF: Payload apagado&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#D4AC0D&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.00 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#D4AC0D&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 1800 s (30.0 min)&lt;br&gt;&lt;font color=&#x27;#D4AC0D&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.0000 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; (ninguno - todo OFF)&lt;br&gt;&amp;#8226; Solo housekeeping del OBC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D4AC0D;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="80" y="60" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_BOOT" value="&lt;b&gt;&lt;u&gt;BOOT: Arranque CM5&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#D4AC0D&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;4.50 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#D4AC0D&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 60 s (1.0 min)&lt;br&gt;&lt;font color=&#x27;#D4AC0D&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.0750 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (boot)&lt;br&gt;&amp;#8226; LDO 5V/3.3V&lt;br&gt;&amp;#8226; eMMC (carga kernel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D4AC0D;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="400" y="60" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_CAL" value="&lt;b&gt;&lt;u&gt;CAL: Calibracion optica&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#7D3C98&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;5.20 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#7D3C98&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 120 s (2.0 min)&lt;br&gt;&lt;font color=&#x27;#7D3C98&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.1733 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (Python)&lt;br&gt;&amp;#8226; Camara IMX477&lt;br&gt;&amp;#8226; LED array (test, baja P)&lt;br&gt;&amp;#8226; Driver STM32G4&lt;br&gt;&amp;#8226; Sensores temperatura" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAEF;strokeColor=#7D3C98;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="720" y="60" width="240" height="260" as="geometry"/></mxCell><mxCell id="P_IDLE" value="&lt;b&gt;&lt;u&gt;IDLE: Espera comando&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;3.00 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 1500 s (25.0 min)&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;1.2500 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (daemon idle)&lt;br&gt;&amp;#8226; Sensores temperatura&lt;br&gt;&amp;#8226; LDO siempre on" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1040" y="60" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_WARM" value="&lt;b&gt;&lt;u&gt;WARMUP: Estab. termica&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;6.00 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 30 s (0.5 min)&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.0500 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (Python)&lt;br&gt;&amp;#8226; LED array (warmup progresivo)&lt;br&gt;&amp;#8226; Driver LEDs&lt;br&gt;&amp;#8226; Sensores temperatura" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1040" y="360" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_CAPT" value="&lt;b&gt;&lt;u&gt;CAPT: Captura FPM&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;8.50 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 180 s (3.0 min)&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.4250 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (capture mode)&lt;br&gt;&amp;#8226; Camara IMX477 (RAW)&lt;br&gt;&amp;#8226; LED array (1 LED ON x captura)&lt;br&gt;&amp;#8226; Driver LEDs (multiplex)&lt;br&gt;&amp;#8226; eMMC (buffer RAW)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1360" y="360" width="240" height="260" as="geometry"/></mxCell><mxCell id="P_PROC" value="&lt;b&gt;&lt;u&gt;PROC: FPM + Real-ESRGAN&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;8.20 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 240 s (4.0 min)&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.5467 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (GPU + CPU full)&lt;br&gt;&amp;#8226; RAM (LPDDR4X full uso)&lt;br&gt;&amp;#8226; eMMC (lectura RAW)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1680" y="360" width="240" height="260" as="geometry"/></mxCell><mxCell id="P_STORE" value="&lt;b&gt;&lt;u&gt;STORE: Compresion + disco&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;3.20 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 30 s (0.5 min)&lt;br&gt;&lt;font color=&#x27;#27AE60&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.0267 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (compress + CRC32)&lt;br&gt;&amp;#8226; eMMC (escritura final)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1680" y="60" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_DLPREP" value="&lt;b&gt;&lt;u&gt;DLPREP: Banda S init&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#2E86C1&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;5.00 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#2E86C1&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 60 s (1.0 min)&lt;br&gt;&lt;font color=&#x27;#2E86C1&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.0833 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (CCSDS packetizer)&lt;br&gt;&amp;#8226; Radio banda S (boot, lock)&lt;br&gt;&amp;#8226; eMMC (lectura archivos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="720" y="400" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_DL" value="&lt;b&gt;&lt;u&gt;DL: Downlink banda S&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#2E86C1&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;12.80 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#2E86C1&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 240 s (4.0 min)&lt;br&gt;&lt;font color=&#x27;#2E86C1&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.8533 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (TX driver)&lt;br&gt;&amp;#8226; &amp;lt;b&amp;gt;Radio banda S (TX 10W RF)&amp;lt;/b&amp;gt;&lt;br&gt;&amp;#8226; eMMC (lectura streaming)&lt;br&gt;&amp;#8226; &amp;lt;i&amp;gt;(estado mas costoso)&amp;lt;/i&amp;gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="400" y="400" width="240" height="260" as="geometry"/></mxCell><mxCell id="P_LP" value="&lt;b&gt;&lt;u&gt;LP: Bajo consumo&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#C0392B&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.55 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#C0392B&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 840 s (14.0 min)&lt;br&gt;&lt;font color=&#x27;#C0392B&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.1283 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (suspend-to-RAM)&lt;br&gt;&amp;#8226; Sensores T (housekeeping)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="80" y="400" width="240" height="240" as="geometry"/></mxCell><mxCell id="P_ERR" value="&lt;b&gt;&lt;u&gt;ERR: Error / retry&lt;/u&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#x27;#C0392B&#x27;&gt;&lt;b&gt;Potencia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;3.50 W&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#C0392B&#x27;&gt;&lt;b&gt;Duracion/orbita:&lt;/b&gt;&lt;/font&gt; 300 s (5.0 min)&lt;br&gt;&lt;font color=&#x27;#C0392B&#x27;&gt;&lt;b&gt;Energia:&lt;/b&gt;&lt;/font&gt; &lt;b&gt;0.2917 Wh/orbita&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;Componentes ON:&lt;/u&gt;&lt;br&gt;&amp;#8226; CM5 (logger + diag)&lt;br&gt;&amp;#8226; Sensores temperatura&lt;br&gt;&amp;#8226; Componente con error en eval." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=8;arcSize=8;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="80" y="720" width="240" height="240" as="geometry"/></mxCell><mxCell id="PEE1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#444;strokeWidth=1.5;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="P_OFF" target="P_BOOT" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="PEE1_T" value="CMD_PL_ON&#10;(OBC -&gt; F)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;labelBackgroundColor=#FFFFFF;fontSize=9;fon