1344.4" y="525.0" width="111.1" height="75.0" as="geometry"/></mxCell><mxCell id="BLK13" value="LP&#10;0.6W&#10;0.128Wh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E74C3C;strokeColor=#A93226;strokeWidth=1.5;fontSize=8;fontStyle=1;fontColor=#1A202C;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1455.6" y="586.2" width="311.1" height="13.8" as="geometry"/></mxCell><mxCell id="BLK14" value="IDLE&#10;3.0W&#10;0.750Wh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#27AE60;strokeColor=#1E8449;strokeWidth=1.5;fontSize=8;fontStyle=1;fontColor=#1A202C;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1766.7" y="525.0" width="333.3" height="75.0" as="geometry"/></mxCell><mxCell id="ZV_BAND" value="Ventana sobre estacion terrena (ZS = 1, 6 min)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5DADE2;strokeColor=#2874A6;fillOpacity=35;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;fontColor=#1B4F72;" vertex="1" parent="1"><mxGeometry x="1211.1" y="670" width="133.3" height="30" as="geometry"/></mxCell><mxCell id="TOTALS" value="&lt;b&gt;Resumen de la orbita&lt;/b&gt;&lt;br&gt;Duracion: &lt;b&gt;5400 s&lt;/b&gt; (90.0 min)&lt;br&gt;Energia total payload: &lt;b&gt;3.862 Wh&lt;/b&gt;&lt;br&gt;Potencia promedio: &lt;b&gt;2.57 W&lt;/b&gt;&lt;br&gt;Pico: &lt;b&gt;12.8 W&lt;/b&gt; (estado DL)&lt;br&gt;&lt;br&gt;&lt;b&gt;Recomendaciones:&lt;/b&gt;&lt;br&gt;&amp;#8226; Mantener OFF durante eclipse&lt;br&gt;&amp;#8226; DL solo en zona ventana (5-10 min)&lt;br&gt;&amp;#8226; PROC fuera de zona ventana (no compite con UHF)&lt;br&gt;&amp;#8226; LP si SOC bateria &amp;lt; 40%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFCFC;strokeColor=#566573;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="100" y="700" width="380" height="200" as="geometry"/></mxCell><mxCell id="COLOR_LEG" value="&lt;b&gt;Categorias de estados:&lt;/b&gt;&lt;br&gt;&lt;font color=&#x27;#D4AC0D&#x27;&gt;&amp;#9608;&lt;/font&gt; Arranque (OFF/BOOT)&lt;br&gt;&lt;font color=&#x27;#7D3C98&#x27;&gt;&amp;#9608;&lt;/font&gt; Calibracion (CAL)&lt;br&gt;&lt;font color=&#x27;#1E8449&#x27;&gt;&amp;#9608;&lt;/font&gt; Operacion (IDLE/CAPT/PROC/STORE)&lt;br&gt;&lt;font color=&#x27;#2874A6&#x27;&gt;&amp;#9608;&lt;/font&gt; Comunicacion (DLPREP/DL)&lt;br&gt;&lt;font color=&#x27;#A93226&#x27;&gt;&amp;#9608;&lt;/font&gt; Safe (LP/ERR)&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFCFC;strokeColor=#566573;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;arcSize=8;" vertex="1" parent="1"><mxGeometry x="520" y="700" width="320" height="200" as="geometry"/></mxCell></root>
